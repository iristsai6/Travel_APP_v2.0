/**
 * 刷新財務計算結果與對帳單
 */

export function refreshFinanceData(groupId) {
    const debtContainer = document.getElementById("splitwise-debts-list");
    const timelineContainer = document.getElementById("expenses-timeline");
    if (!debtContainer || !timelineContainer) return;

    // 模擬當前成員支出總量結構
    const mockExpenses = [
        { title: "前夜祭燒肉", amount: 6000, paidBy: "小明", splitWith: ["小明", "小華", "小美"] },
        { title: "高級商務旅館包棟", amount: 15000, paidBy: "小華", splitWith: ["小明", "小華", "小美"] }
    ];

    // 呼叫貪婪分帳演算法
    const optimizedTransfers = calculateSplitwiseDebts(mockExpenses);

    // 渲染分帳優化結果
    debtContainer.innerHTML = optimizedTransfers.map(t => `
        <div class="p-3 bg-slate-50 dark:bg-zinc-800/40 rounded-xl text-sm flex justify-between items-center">
            <span><strong>${t.from}</strong> 應轉帳給 <strong>${t.to}</strong></span>
            <span class="text-orange-500 font-bold">$${t.amount.toFixed(0)}</span>
        </div>
    `).join('') || `<p class="text-xs text-slate-400 text-center py-2">所有帳目已平，真棒！</p>`;

    // 渲染流水帳明細
    timelineContainer.innerHTML = mockExpenses.map(exp => `
        <div class="glass-panel p-4 rounded-xl flex justify-between items-center">
            <div class="space-y-1">
                <h4 class="font-bold text-sm">${exp.title}</h4>
                <p class="text-xs text-slate-400">付款人：${exp.paidBy} ‧ 平分人數：${exp.splitWith.length}人</p>
            </div>
            <div class="text-right">
                <span class="text-base font-extrabold tracking-tight">$${exp.amount}</span>
            </div>
        </div>
    `).join('');
}

/**
 * 開啟新增費用視窗
 */
function openAddExpenseModal(groupId) {
    openModal(`
        <h3 class="text-xl font-bold mb-4">記一筆旅團帳目</h3>
        <div class="space-y-3">
            <input type="text" id="modal-exp-title" placeholder="品項名稱，例：新幹線車票" class="w-full px-4 py-2.5 bg-slate-100 dark:bg-zinc-800 border-0 rounded-xl text-sm">
            <input type="number" id="modal-exp-amount" placeholder="金額 (TWD)" class="w-full px-4 py-2.5 bg-slate-100 dark:bg-zinc-800 border-0 rounded-xl text-sm">
            <select id="modal-exp-payer" class="w-full px-4 py-2.5 bg-slate-100 dark:bg-zinc-800 border-0 rounded-xl text-sm">
                <option value="me">由我付清</option>
            </select>
            <div class="flex gap-2 pt-2">
                <button id="modal-exp-cancel" class="flex-1 py-2.5 bg-slate-100 dark:bg-zinc-800 rounded-xl font-semibold text-sm">取消</button>
                <button id="modal-exp-submit" class="flex-1 py-2.5 bg-emerald-500 text-white rounded-xl font-semibold text-sm">確認記帳</button>
            </div>
        </div>
    `);

    document.getElementById("modal-exp-cancel").addEventListener("click", closeModal);
    document.getElementById("modal-exp-submit").addEventListener("click", () => {
        showToast("費用登錄成功！", "success");
        closeModal();
    });
}
